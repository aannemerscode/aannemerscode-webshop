# Kopieer dit bestand naar ".env" en vul je eigen gegevens in.
# Zet ".env" nooit in git / deel het nergens — het bevat geheime sleutels.

# --- Mollie ---
# Haal je API-key op via https://my.mollie.com/dashboard/ -> Developers -> API keys
# Begin met de "test_..." key om zonder echt geld te testen, ga pas live met "live_..."
MOLLIE_API_KEY=test_jouwsleutelhier

# De publieke URL waarop deze site straks live staat (zonder trailing slash)
# Lokaal testen: http://localhost:3000
BASE_URL=http://localhost:3000

PORT=3000

# --- Jouw bedrijfsgegevens (komen op elke factuur te staan) ---
# Zonder KVK/btw-nummer mag je wettelijk geen facturen versturen — vul ze dus in
# voordat je live gaat. De server logt een waarschuwing als ze ontbreken.
SELLER_NAME=AannemersCode
SELLER_ADDRESS_LINE1=
SELLER_ADDRESS_LINE2=
SELLER_KVK=
SELLER_BTW=
SELLER_IBAN=

# --- Prijzen (optioneel, anders gelden de standaardwaarden uit server.js) ---
PRICE_CURSUS=325.00
PRICE_REKENTOOL=175.00
PRICE_BUNDEL=450.00

# --- Downloadlinks die na betaling gemaild worden ---
# Zet hier een link naar je eigen bestand (bv. een Google Drive-link met "iedereen met de link
# kan bekijken", of een link naar privé-bestandsopslag zoals AWS S3 / Backblaze).
DOWNLOAD_URL_CURSUS=
DOWNLOAD_URL_REKENTOOL=
DOWNLOAD_URL_BUNDEL=

# --- E-mail (voor het versturen van downloadlinks na betaling) ---
# Voorbeeld met Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false,
# SMTP_USER=jouw@gmail.com, SMTP_PASS=een "app-wachtwoord" (niet je gewone wachtwoord)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=AannemersCode <no-reply@aannemerscode.nl>

# E-mailadres waarop jij zelf een seintje krijgt bij elke verkoop
OWNER_EMAIL=
